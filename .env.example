# Firebase Configuration Environment Variables Template
# Copy this file to .env and replace placeholder strings with production credentials.
FIREBASE_PROJECT_ID=pantri-app-stub
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_STORAGE_BUCKET=pantri-app-stub.appspot.com

# Platform Specific API Keys
FIREBASE_API_KEY_WEB=AIzaSyA_STUB_WEB_API_KEY_REPLACE_ME
FIREBASE_APP_ID_WEB=1:1234567890:web:abcdef123456
FIREBASE_AUTH_DOMAIN_WEB=pantri-app-stub.firebaseapp.com

FIREBASE_API_KEY_ANDROID=AIzaSyA_STUB_ANDROID_API_KEY_REPLACE_ME
FIREBASE_APP_ID_ANDROID=1:1234567890:android:abcdef123456

FIREBASE_API_KEY_IOS=AIzaSyA_STUB_IOS_API_KEY_REPLACE_ME
FIREBASE_APP_ID_IOS=1:1234567890:ios:abcdef123456
FIREBASE_IOS_BUNDLE_ID=com.example.pantri

FIREBASE_API_KEY_MACOS=AIzaSyA_STUB_MACOS_API_KEY_REPLACE_ME
FIREBASE_APP_ID_MACOS=1:1234567890:ios:abcdef123456
